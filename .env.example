# Porta do servidor HTTP
PORT=8080

# String de conexão com o Postgres.
# Em docker-compose: postgres://clube:clube@db:5432/clube?sslmode=disable
DATABASE_URL=postgres://clube:clube@localhost:5432/clube?sslmode=disable

# Segredo usado para assinar os tokens JWT de sessão.
# Gere algo longo em produção (ex.: openssl rand -hex 32).
JWT_SECRET=change-me-em-producao

# Configuração de SMTP para lembretes de encontros.
# Deixe SMTP_HOST vazio para desabilitar o envio de e-mails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=clube@exemplo.com

# Chave de API do Google Books (opcional; a API funciona sem chave, com limites).
GOOGLE_BOOKS_API_KEY=

# Credenciais do usuário administrador seed criado na primeira execução.
ADMIN_EMAIL=admin@clube.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador
